<!DOCTYPE html>
<html lang="fi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Izza Pizza</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #fff8f0;
            margin: 0;
            padding: 0;
        }
        header {
            background-color: #ff4d4d;
            color: white;
            padding: 20px;
            text-align: center;
        }
        nav {
            background-color: #ff9999;
            padding: 10px;
            text-align: center;
        }
        nav a {
            color: white;
            margin: 0 15px;
            text-decoration: none;
            font-weight: bold;
        }
        main {
            padding: 20px;
        }
        .menu-item {
            border: 1px solid #ff9999;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 5px;
            background-color: #fff0f0;
        }
        footer {
            background-color: #ff4d4d;
            color: white;
            text-align: center;
            padding: 15px;
        }
        button {
            background-color: #ff4d4d;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 3px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <header>
        <h1>Izza Pizza</h1>
        <p>Herkkupizzoja suoraan kotiin!</p>
    </header>

    <nav>
        <a href="#menu">Menu</a>
        <a href="#tilaa">Tilaa</a>
        <a href="#yhteystiedot">Yhteystiedot</a>
    </nav>

    <main>
        <section id="menu">
            <h2>Menu</h2>
            <div class="menu-item">
                <h3>Margherita</h3>
                <p>Tomaatikastike, juusto</p>
                <p>Hinta: 8€</p>
                <button>Lisää koriin</button>
            </div>
            <div class="menu-item">
                <h3>Pepperoni</h3>
                <p>Tomaatikastike, juusto, pepperoni</p>
                <p>Hinta: 10€</p>
                <button>Lisää koriin</button>
            </div>
            <div class="menu-item">
                <h3>Veggie</h3>
                <p>Tomaatikastike, juusto, paprika, sipuli, oliivit</p>
                <p>Hinta: 9€</p>
                <button>Lisää koriin</button>
            </div>
        </section>

        <section id="tilaa">
            <h2>Tilaa Pizza</h2>
            <p>Valitettavasti demo-sivulla ei voi oikeasti maksaa, mutta voit klikata "Lisää koriin".</p>
        </section>

        <section id="yhteystiedot">
            <h2>Yhteystiedot</h2>
            <p>Osoite: Napaketuntie 10, Porvoo</p>
            <p>Puhelin: 040 123 4567</p>
            <p>Email: info@izzapizza.fi</p>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Izza Pizza</p>
    </footer>
</body>
</html>